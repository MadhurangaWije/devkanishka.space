# The /ask (Ask Me) page sends question notifications + confirmations by
# authenticating directly to Gmail's SMTP as 123kanishka@gmail.com (see
# OWNER_EMAIL in src/app/api/ask/route.ts) — no custom sending domain needed.
#
# To get an app password: enable 2-Step Verification on that Google account,
# then create an "App Password" at https://myaccount.google.com/apppasswords
# (choose "Mail" as the app) and paste the 16-character value below.
GMAIL_APP_PASSWORD=

# ── Guide chatbot (RAG) ──────────────────────────────────────────────────
# Gemini API key (also used for embeddings, regardless of LLM_PROVIDER below).
# Get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Supabase project (Settings → API). The service-role key is server-only —
# never expose it to the client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Which model answers questions: "google" (default, Gemini Flash) or
# "openrouter". Embeddings always stay on Gemini regardless of this setting.
LLM_PROVIDER=google
# Only needed when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=
# Optional override — defaults are set in src/lib/ai/providers.ts.
CHAT_MODEL=

# ── Memories app (memories.devkanishka.space) ───────────────────────────────
# Photos are stored in Google Drive; only Drive file ids are kept in Supabase
# (see supabase/schema.sql). Setup:
#   1. In Google Cloud Console, enable the "Google Drive API" on a project
#      (the same project used for GOOGLE_GENERATIVE_AI_API_KEY is fine).
#   2. APIs & Services → Credentials → Create OAuth client ID → type
#      "Desktop app". Paste its client id/secret below.
#   3. Run `npm run drive-auth` — it walks you through a one-time Google
#      sign-in, then prints GOOGLE_OAUTH_REFRESH_TOKEN and
#      GOOGLE_DRIVE_FOLDER_ID (a fresh Drive folder it creates for you) to
#      paste in below. Sign in with whichever Google account should own the
#      photos — the app can only ever see files it creates itself (scope is
#      drive.file, not full Drive access).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# Shared password gating the "owner" session (adding/editing memories, and
# viewing ones marked private). Pick something only the two of you know.
OWNER_PASSWORD=
# Random secret used to sign the owner session cookie — generate with
# `openssl rand -hex 32` (or any long random string). Changing it logs
# everyone out.
OWNER_SESSION_SECRET=
